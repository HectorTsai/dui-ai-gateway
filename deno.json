{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --unstable-cron --watch main.ts",
    "build:css": "deno run -A npm:@tailwindcss/cli -i input.css -o static/style.css",
    "dev:css": "deno run -A npm:@tailwindcss/cli -i input.css -o static/style.css --watch"
  },
  "imports": {
    "@dui/database": "jsr:@dui/database@^1.0.1",
    "@dui/smartmultilingual": "jsr:@dui/smartmultilingual@^0.2.3",
    "@std/assert": "jsr:@std/assert@1",
    "hono": "npm:hono@^4",
    "@tailwindcss/cli": "npm:@tailwindcss/cli@^4",
    "daisyui": "npm:daisyui@^5",
    "tailwindcss": "npm:tailwindcss@^4"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
